# Copy this to server/.env — Neo4j is required (server exits if DB is unreachable)

NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password-here
NEO4J_DATABASE=neo4j

ROCKETRIDE_URI=https://cloud.rocketride.ai
ROCKETRIDE_APIKEY=rr-xxxxxxxxxxxxxxxxxxxxxxxx
ROCKETRIDE_PIPELINE_FILE=smartnetworking-ai.pipe
ROCKETRIDE_MISTRAL_KEY=your-mistral-api-key
ROCKETRIDE_OPENAI_KEY=sk-xxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxx
OPENAI_FALLBACK_MODEL=gpt-4o-mini
ROCKETRIDE_TIMEOUT_MS=8000
AI_FALLBACK_MODE=false
AI_SKIP_ROCKETRIDE=false

PORT=4000
CLIENT_ORIGIN=http://localhost:5173
