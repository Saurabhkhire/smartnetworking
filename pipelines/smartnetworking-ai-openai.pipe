{
	"components": [
		{
			"id": "chat_1",
			"provider": "chat",
			"config": { "hideForm": true, "mode": "Source", "parameters": {}, "type": "chat" }
		},
		{
			"id": "prompt_1",
			"provider": "prompt",
			"config": {
				"instructions": [
					"You assist the Smart Networking (VentureGraph) backend. Be precise, concise, and follow the caller's formatting constraints exactly (word limits, sentence counts, tone)."
				]
			},
			"input": [{ "lane": "questions", "from": "chat_1" }]
		},
		{
			"id": "llm_openai_1",
			"provider": "llm_openai",
			"config": {
				"profile": "openai-4o-mini",
				"openai-4o-mini": { "apikey": "${ROCKETRIDE_OPENAI_KEY}" }
			},
			"input": [{ "lane": "questions", "from": "prompt_1" }]
		},
		{
			"id": "response_1",
			"provider": "response_answers",
			"config": {},
			"input": [{ "lane": "answers", "from": "llm_openai_1" }]
		}
	],
	"project_id": "b2c3d4e5-f6a7-48b9-c0d1-e2f3a4b5c6d7",
	"source": "chat_1",
	"viewport": { "x": 0, "y": 0, "zoom": 1 },
	"version": 1
}
