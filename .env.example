# ─── Neo4j (required — server will not start without a working connection) ─
# AuraDB Free — get from console.neo4j.io → New Instance → AuraDB Free
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password-here
NEO4J_DATABASE=neo4j

# ─── RocketRide (Local engine) ──────────────────────────────────────────────
# This project is wired to use a LOCAL RocketRide engine + local pipeline file.
# Start your RocketRide engine, then point to it here.
ROCKETRIDE_URI=http://127.0.0.1:5565
# Local engine usually doesn't require a RocketRide API key; leave unset.
# ROCKETRIDE_APIKEY=

# Pipeline under ./pipelines/ — default is `new-pipeline.pipe`
ROCKETRIDE_PIPELINE_FILE=new-pipeline.pipe

# When RocketRide or the pipeline LLM fails, direct OpenAI Chat Completions (recommended for chatbots):
OPENAI_API_KEY=sk-xxxxxxxx
OPENAI_FALLBACK_MODEL=gpt-4o-mini
# OpenAI-only: long timeout for big chatbot prompts (default 120s if unset). Do not reuse 8000ms — it aborts mid-request.
OPENAI_TIMEOUT_MS=120000
# Placeholder ROCKETRIDE_APIKEY (rr-xxx…) is auto-skipped; set a real key or rely on OPENAI_API_KEY above.

ROCKETRIDE_TIMEOUT_MS=8000

# true = stub text only (no RocketRide, no OpenAI)
AI_FALLBACK_MODE=false
# true = skip RocketRide and use OPENAI_API_KEY only (set this if you only use OpenAI / no DAP)
AI_SKIP_ROCKETRIDE=false
# Same as AI_SKIP_ROCKETRIDE — never call RocketRide, only OpenAI
# OPENAI_ONLY=true

# ─── Database driver ────────────────────────────────────────────────────────
# DB_DRIVER=neo4j   (default — uses NEO4J_* vars above)
# DB_DRIVER=sqlite  (no Neo4j needed; DB file created at server/venturegraph.db)
DB_DRIVER=neo4j

# SQLite path (only used when DB_DRIVER=sqlite)
# SQLITE_PATH=./venturegraph.db

# ─── Email (optional — needed for Send Schedule feature) ────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=VentureGraph <your@gmail.com>

# ─── Server ─────────────────────────────────────────────────────────────────
PORT=4000
CLIENT_ORIGIN=http://localhost:5173
